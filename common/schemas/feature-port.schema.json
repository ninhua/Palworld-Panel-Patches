{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Third-party Feature Port Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "feature_id",
    "source",
    "target",
    "status",
    "license_review"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "feature_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "source": {
      "type": "object",
      "required": ["repository", "commit", "paths"]
    },
    "target": {
      "type": "object",
      "required": ["project", "implementation"]
    },
    "status": {
      "enum": ["planned", "researching", "implementing", "testing", "released", "rejected"]
    },
    "license_review": {
      "type": "object",
      "required": ["completed", "notes"]
    }
  }
}
