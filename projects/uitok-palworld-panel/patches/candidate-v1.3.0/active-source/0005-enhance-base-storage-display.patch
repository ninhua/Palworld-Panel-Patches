+		return ""
+	}
+	if translated := strings.TrimSpace(names.technologies[normalize(trimmed)]); translated != "" {
+		return translated
+	}
+	switch normalize(trimmed) {
+	case "itemchest":
+		return "木箱"
+	case "itemchest_02":
+		return "金属箱"
+	case "itemchest_03":
+		return "精炼金属箱"
+	case "itemchest_04":
