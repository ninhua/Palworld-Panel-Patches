+	case "coolerpalfoodbox":
+		return "低温保鲜饲料箱"
+	case "refrigerator":
+		return "冰箱"
+	}
+	localized := MapObjectName(trimmed)
+	if localized != trimmed {
+		return localized
+	}
+	return trimmed
+}
